#!/usr/bin/env bash
# Pre-commit secret scanner for the PUBLIC homelab-infra repo.
# Blocks a commit if staged changes look like they contain a real secret.
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail

# Only scan what's actually staged (added/changed lines).
staged_diff() { git diff --cached --no-color -U0; }

# Patterns that should NEVER land in a public repo.
# Each: "human label|regex"
PATTERNS=(
  "Proxmox API token|root@pam![[:alnum:]_-]+=[0-9a-fA-F-]{8,}"
  "Private key block|BEGIN (OPENSSH|RSA|EC|DSA|PGP) PRIVATE KEY"
  "AWS access key|AKIA[0-9A-Z]{16}"
  "Generic secret assignment|(password|passwd|secret|token|api[_-]?key)[[:space:]]*[:=][[:space:]]*[\"']?[^\"'[:space:]]{8,}"
  "UUID that looks like a token|[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
  "Your real mail domain|jchoo\.me"
  "Your real web domain|chooys\.com"
)

# Lines allowed to contain matches (placeholders / examples).
ALLOWLIST_REGEX='(<secret>|changeme|example\.|CHANGE-?ME|\.env\.example|PASTE:|your-domain|your-mail|xxxx|AAAA)'

found=0
diff="$(staged_diff || true)"
# Only look at added lines (start with + but not +++ header).
added="$(printf '%s\n' "$diff" | grep -E '^\+' | grep -Ev '^\+\+\+' || true)"

while IFS='|' read -r label regex; do
  hits="$(printf '%s\n' "$added" | grep -En "$regex" | grep -Ev "$ALLOWLIST_REGEX" || true)"
  if [ -n "$hits" ]; then
    echo "🚨 pre-commit: possible $label in staged changes:"
    printf '%s\n' "$hits" | sed 's/^/    /'
    found=1
  fi
done < <(printf '%s\n' "${PATTERNS[@]}")

if [ "$found" -ne 0 ]; then
  cat <<'MSG'

Commit BLOCKED — staged changes look like they contain secrets or private info.
 • If it's a real secret: remove it, use <secret> / .env.example, and re-stage.
 • If it's a false positive: bypass once with  git commit --no-verify
MSG
  exit 1
fi
exit 0
